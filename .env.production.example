# Ambiente de Produção - whatsrifas.com.br
# Copie este arquivo para .env.production.local ou configure no CyberPanel

NODE_ENV=production
PORT=3088

# Banco de Dados MySQL
DATABASE_URL="mysql://usuario:senha@localhost:3306/rifasonline"

# JWT Secret
JWT_SECRET="rifasonline-secret-key-2024"

# NextAuth URL
NEXTAUTH_URL="https://whatsrifas.com.br"
NEXTAUTH_SECRET="rifasonline-nextauth-secret"

# WhatsApp (se necessário)
# WHATSAPP_SESSION_PATH="./sessions"

# PagSeguro (se necessário)
# PAGSEGURO_EMAIL=""
# PAGSEGURO_TOKEN=""

# Outros
NEXT_PUBLIC_API_URL="https://whatsrifas.com.br"
