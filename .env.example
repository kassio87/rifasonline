# Banco de Dados MySQL
DATABASE_URL="mysql://usuario:senha@localhost:3306/rifasonline"

# JWT Secret
JWT_SECRET="seu_jwt_secret_aqui"
NEXTAUTH_SECRET="seu_nextauth_secret_aqui"

# WhatsApp API (não oficial)
WHATSAPP_SESSION_PATH="./whatsapp_sessions"

# Configurações do Sistema
SYSTEM_NAME="RifasOnline"
SYSTEM_URL="http://localhost:3000"

# PagSeguro (opcional)
PAGSEGURO_EMAIL="seu_email@pagseguro.com"
PAGSEGURO_TOKEN="seu_token_pagseguro"

# Webhook URLs (para configurar no PagSeguro/banco)
WEBHOOK_BASE_URL="http://seu-dominio.com"
